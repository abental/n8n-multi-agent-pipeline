      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [250, 300],
      "webhookId": "text-tool-webhook"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body;\nconst request_id = body.request_id || 'unknown';\nconst text = (body.text || '').trim();\nreturn [{ json: { request_id, text } }];"
      },
      "id": "c-prepare",
      "name": "PreparePayload",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [470, 300]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "http://torch-infer:8000/text/classify",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ request_id: $json.request_id, text: $json.text }) }}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "c-http-classify",
      "name": "TorchInfer Classify",
      "type": "n8n-nodes-base.httpRequest",
