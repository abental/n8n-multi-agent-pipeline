      "typeVersion": 4.2,
      "position": [910, 300]
    },
    {
      "parameters": {
        "jsCode": "const classify = $('TorchInfer Classify').first().json;\nconst extract = $input.first().json;\nreturn [{\n  json: {\n    request_id: classify.request_id,\n    classification: classify.classification,\n    entities: extract.entities || [],\n    model: classify.model,\n    notes: classify.notes || null\n  }\n}];"
      },
      "id": "c-merge",
