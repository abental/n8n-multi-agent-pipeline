        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={{ JSON.stringify({ request_id: $('PreparePayload').first().json.request_id, text: $('PreparePayload').first().json.text }) }}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "c-http-extract",
      "name": "TorchInfer Extract",
