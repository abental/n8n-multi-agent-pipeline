# === llama.cpp (Python server) ===
MODEL_REPO=QuantFactory/Meta-Llama-3-8B-Instruct-GGUF
MODEL_FILE=Meta-Llama-3-8B-Instruct.Q4_K_M.gguf
LLM_CONTEXT_SIZE=4096
LLM_PORT=8080

# === n8n ===
N8N_PORT=5678
N8N_SECURE_COOKIE=false
WEBHOOK_URL=http://localhost:5678/

# === Torch-Infer ===
TORCH_INFER_PORT=8000
VISION_SCORE_THRESHOLD=0.5
TEXT_CANDIDATE_LABELS=maintenance_issue,safety_hazard,normal_operation,equipment_failure,environmental_concern

# === Torch-Infer URL (how n8n reaches Torch-Infer) ===
# Docker mode (default): torch-infer runs in Docker, n8n uses Docker DNS
#   TORCH_INFER_BASE_URL=http://torch-infer:8000
# Local debug mode: torch-infer runs on host (e.g. PyCharm), n8n uses host gateway
#   TORCH_INFER_BASE_URL=http://host.docker.internal:8000
